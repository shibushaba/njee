# Copy to .env.local (never commit secrets).
# Create two Auth users in Supabase (email/password): finu@nje.app and shibu@nje.app
# Disable public sign-ups under Authentication → Providers → Email.
#
# Vercel: add the same VITE_* keys under Project → Settings → Environment Variables,
# then Redeploy so the values are baked into the build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Memories → Google Drive (optional locally; required for Drive uploads)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_DRIVE_ROOT_FOLDER_ID=
# VITE_GOOGLE_SHARED_DRIVE_ID=

